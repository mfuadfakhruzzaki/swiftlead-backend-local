# ================================================
# SwiftLead Backend - Local Environment Config
# ================================================
# Copy file ini menjadi .env dan sesuaikan nilainya
# cp .env.example .env
# ================================================

# ---- Docker Image ----
# Ganti jika menggunakan registry lain
BACKEND_IMAGE=ghcr.io/mfuadfakhruzzaki/swiftlead-backend:latest

# ---- Server ----
PORT=8080
ENV=development
LOG_LEVEL=debug
DEBUG=true

# ---- Database (PostgreSQL + TimescaleDB) ----
DB_USER=swiftlet
DB_PASSWORD=swiftlet123
DB_NAME=swiftlet
DB_PORT=5432
POSTGRES_DSN=host=db user=swiftlet password=swiftlet123 dbname=swiftlet port=5432 sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# ---- JWT Authentication ----
JWT_SECRET=ganti-dengan-secret-key-yang-kuat
JWT_EXPIRATION_HOURS=24

# ---- MinIO Object Storage ----
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=swiftlet
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---- MQTT Broker ----
MQTT_BROKER=tcp://mosquitto:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=swiftlead-backend
MQTT_TOPIC_PREFIX=swiftlead/tel
MQTT_KEEPALIVE=30
MQTT_CONNECT_TIMEOUT=5
MQTT_PORT=1883
MQTT_TLS_PORT=8883

# MQTT TLS (optional - ganti MQTT_BROKER ke ssl://mosquitto:8883)
MQTT_USE_TLS=false
MQTT_CA_CERT=
MQTT_CLIENT_CERT=
MQTT_CLIENT_KEY=
MQTT_SKIP_VERIFY=false

# ---- AI Engine (optional) ----
AI_ENGINE_URL=http://localhost:8000
AI_ENGINE_TIMEOUT=5
AI_ENGINE_ENABLED=false

# ---- CORS ----
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Accept,Authorization,Content-Type,X-CSRF-Token
CORS_ALLOW_CREDENTIALS=true

# ---- Sensor Thresholds ----
TEMP_HIGH_THRESHOLD=35.0
TEMP_LOW_THRESHOLD=20.0
HUMID_HIGH_THRESHOLD=85.0
HUMID_LOW_THRESHOLD=60.0
AMMONIA_HIGH_THRESHOLD=25.0
NODE_OFFLINE_THRESHOLD_MINUTES=15
SENSOR_DATA_RETENTION_DAYS=365

# ---- File Uploads ----
MAX_UPLOAD_SIZE_MB=10
MAX_AVATAR_SIZE_MB=2
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,webp

# ---- Server Timeouts ----
SERVER_READ_TIMEOUT=15
SERVER_WRITE_TIMEOUT=15
SERVER_IDLE_TIMEOUT=60
SHUTDOWN_TIMEOUT=30
REQUEST_TIMEOUT=60

# ---- Monitoring ----
PROMETHEUS_PORT=9090
GRAFANA_PORT=3030
GRAFANA_ADMIN_PASSWORD=swiftlead_admin
